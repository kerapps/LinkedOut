{
  "manifest_version": 3,
  "name": "BuzzKill — LinkedIn Corporate Speak Translator",
  "version": "1.2.8",
  "description": "Translates LinkedIn corporate speak into plain human language. Cut through the hype and humble-brags.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "homepage_url": "https://github.com/kerapps/BuzzKill",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "config.js",
        "translator.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon16.png",
        "icons/icon48.png"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}
